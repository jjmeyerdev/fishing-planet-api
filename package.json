{
  "name": "fishing-planet-api",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "RATE_LIMIT_MAX=0 API_KEYS= LOG_SILENT=1 vitest run",
    "test:watch": "RATE_LIMIT_MAX=0 API_KEYS= LOG_SILENT=1 vitest",
    "seed": "tsx scripts/seed.ts",
    "seed:biting": "tsx scripts/seed-biting-preferences.ts",
    "seed:gear": "tsx scripts/seed-gear.ts",
    "seed:fp": "tsx scripts/seed-fp.ts",
    "seed:spots": "tsx scripts/seed-spots.ts",
    "wiki:crawl": "tsx scripts/wiki/crawl.ts",
    "wiki:parse": "tsx scripts/wiki/parse.ts",
    "wiki:load": "tsx scripts/wiki/load.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mendable/firecrawl-js": "^4.29.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
