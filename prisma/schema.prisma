generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  // Emit .js extensions on relative imports so the tsc-compiled client runs
  // under Node's ESM resolver (node dist/index.js); tsx tolerates either in dev.
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model Fish {
  id             Int     @id @default(autoincrement())
  commonName     String  @unique @map("common_name") @db.VarChar(100)
  scientificName String? @map("scientific_name") @db.VarChar(100)
  family         String? @db.VarChar(50)
  description    String? @db.Text
  isEventFish    Boolean @default(false) @map("is_event_fish")
  isMonster      Boolean @default(false) @map("is_monster")

  // FP-Collective source metadata (the ID is the join key for the JSON dataset)
  fpId     Int?    @unique @map("fp_id")
  slug     String? @unique @db.VarChar(120)
  imageUrl String? @map("image_url") @db.Text

  // Weights (stored in kg)
  weightYoungMin      Decimal? @map("weight_young_min")
  weightYoungMax      Decimal? @map("weight_young_max")
  weightCommonMin     Decimal? @map("weight_common_min")
  weightCommonMax     Decimal? @map("weight_common_max")
  weightTrophyMin     Decimal? @map("weight_trophy_min")
  weightUniqueMin     Decimal? @map("weight_unique_min")
  weightUniqueMax     Decimal? @map("weight_unique_max")
  monsterTargetWeight Decimal? @map("monster_target_weight")

  // Financials (base rates)
  creditsPerKgCommon Decimal? @map("credits_per_kg_common")
  creditsPerKgTrophy Decimal? @map("credits_per_kg_trophy")
  creditsPerKgUnique Decimal? @map("credits_per_kg_unique")

  xpCurveNotes    String?   @map("xp_curve_notes") @db.Text
  farmingMetaTier String?   @map("farming_meta_tier") @db.VarChar(10)
  notesFarming    String?   @map("notes_farming") @db.Text
  dataVersion     String?   @map("data_version") @db.VarChar(20)
  lastVerified    DateTime? @map("last_verified") @db.Date

  locations        FishLocation[]
  bitingPreference BitingPreference?
  baits            FishBait[]
  lureTypes        FishLureType[]

  @@map("fish")
}

model Location {
  id           Int    @id @default(autoincrement())
  name         String @unique @db.VarChar(100)
  region       String @db.VarChar(50)
  waterwayType String @map("waterway_type") @db.VarChar(50)
  unlockLevel  Int    @map("unlock_level")

  // FP-Collective source metadata (the ID is the join key for the JSON dataset)
  fpId     Int?    @unique @map("fp_id")
  slug     String? @unique @db.VarChar(120)
  imageUrl String? @map("image_url") @db.Text

  fish     FishLocation[]
  spots    Spot[]
  weathers Weather[]

  @@map("locations")
}

model FishLocation {
  fishId         Int      @map("fish_id")
  locationId     Int      @map("location_id")
  specificSpot   String   @map("specific_spot") @db.VarChar(100)
  classesPresent String[] @map("classes_present") @db.VarChar(50)

  fish     Fish     @relation(fields: [fishId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@id([fishId, locationId, specificSpot])
  @@map("fish_locations")
}

model BitingPreference {
  fishId              Int      @id @map("fish_id")
  preferredBaits      String[] @map("preferred_baits")
  preferredLures      String[] @map("preferred_lures")
  // Flagged as disputed/soft heuristic in documentation
  preferredLureColors String[] @map("preferred_lure_colors")
  hookSizeMin         String?  @map("hook_size_min") @db.VarChar(10)
  hookSizeMax         String?  @map("hook_size_max") @db.VarChar(10)
  depthZone           String?  @map("depth_zone") @db.VarChar(20)
  sunnyPeakTimes      String?  @map("sunny_peak_times") @db.Text
  cloudyPeakTimes     String?  @map("cloudy_peak_times") @db.Text
  rainyPeakTimes      String?  @map("rainy_peak_times") @db.Text

  fish Fish @relation(fields: [fishId], references: [id])

  @@map("biting_preferences")
}

// --- FP-Collective structured dataset (spots, weather, tackle catalog) ---

model Spot {
  id         Int     @id @default(autoincrement())
  fpId       Int     @unique @map("fp_id")
  name       String  @db.VarChar(100)
  slug       String  @unique @db.VarChar(120)
  title      String  @db.VarChar(150)
  // Game-map coordinates, not WGS84 (values fall well outside lat/lng ranges)
  lat        Decimal
  lng        Decimal
  x          Decimal
  y          Decimal
  imageUrl   String? @map("image_url") @db.Text
  locationId Int     @map("location_id")

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@map("spots")
}

model Weather {
  id          Int     @id @default(autoincrement())
  fpId        Int     @unique @map("fp_id")
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(120)
  title       String  @db.VarChar(150)
  value       String  @db.VarChar(50)
  legacyValue String  @map("legacy_value") @db.VarChar(20)
  type        String  @db.VarChar(10)
  iconUrl     String? @map("icon_url") @db.Text
  chartUrl    String? @map("chart_url") @db.Text
  locationId  Int     @map("location_id")

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@map("weathers")
}

model Bait {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  baitType      String   @map("bait_type") @db.VarChar(50)
  tags          String[]

  fishes FishBait[]

  @@map("baits")
}

model Boilie {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  baitType      String   @map("bait_type") @db.VarChar(50)
  diameterMm    Int?     @map("diameter_mm")
  tags          String[]

  @@map("boilies")
}

model LureType {
  id       Int      @id @default(autoincrement())
  fpId     Int      @unique @map("fp_id")
  title    String   @db.VarChar(150)
  slug     String   @unique @db.VarChar(150)
  imageUrl String?  @map("image_url") @db.Text
  tags     String[]

  lures  Lure[]
  fishes FishLureType[]

  @@map("lure_types")
}

model Lure {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  color         String?  @db.VarChar(50)
  weightG       Decimal? @map("weight_g")
  lengthCm      Decimal? @map("length_cm")
  tags          String[]
  lureTypeId    Int?     @map("lure_type_id")

  lureType LureType? @relation(fields: [lureTypeId], references: [id])

  @@index([lureTypeId])
  @@map("lures")
}

model Hook {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  size          String   @db.VarChar(20)
  type          String   @db.VarChar(50)
  tags          String[]

  @@map("hooks")
}

model Jighead {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  size          String   @db.VarChar(20)
  weightG       Decimal? @map("weight_g")
  color         String?  @db.VarChar(50)
  tags          String[]

  @@map("jigheads")
}

model Sinker {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  form          String   @db.VarChar(50)
  weightG       Decimal? @map("weight_g")
  color         String?  @db.VarChar(50)
  tags          String[]

  @@map("sinkers")
}

model Keepnet {
  id             Int     @id @default(autoincrement())
  fpId           Int     @unique @map("fp_id")
  title          String  @db.VarChar(150)
  slug           String  @unique @db.VarChar(150)
  imageUrl       String? @map("image_url") @db.Text
  baseLevel      Int     @map("base_level")
  baitcoinLevel  Int     @map("baitcoin_level")
  type           String  @db.VarChar(50)
  isFishFriendly Boolean @map("is_fish_friendly")

  @@map("keepnets")
}

model Addon {
  id            Int      @id @default(autoincrement())
  fpId          Int      @unique @map("fp_id")
  title         String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  imageUrl      String?  @map("image_url") @db.Text
  baseLevel     Int      @map("base_level")
  baitcoinLevel Int      @map("baitcoin_level")
  color         String?  @db.VarChar(50)
  lengthCm      Decimal? @map("length_cm")
  tags          String[]

  @@map("addons")
}

model FishBait {
  fishId Int @map("fish_id")
  baitId Int @map("bait_id")

  fish Fish @relation(fields: [fishId], references: [id])
  bait Bait @relation(fields: [baitId], references: [id])

  @@id([fishId, baitId])
  @@index([baitId])
  @@map("fish_baits")
}

model FishLureType {
  fishId     Int @map("fish_id")
  lureTypeId Int @map("lure_type_id")

  fish     Fish     @relation(fields: [fishId], references: [id])
  lureType LureType @relation(fields: [lureTypeId], references: [id])

  @@id([fishId, lureTypeId])
  @@index([lureTypeId])
  @@map("fish_lure_types")
}

// --- Fishing Planet Wiki (wiki.fishingplanet.com) import — standalone dataset ---
// Kept fully separate from the FP-Collective models above. Vertical slice:
// species + reels (+ brands, technologies, and the wiki links they reference).

model WikiSpecies {
  id                 Int      @id @default(autoincrement())
  slug               String   @unique @db.VarChar(160)
  name               String   @db.VarChar(120)
  latinName          String?  @map("latin_name") @db.VarChar(120)
  family             String?  @db.VarChar(80)
  description        String?  @db.Text
  imageUrl           String?  @map("image_url") @db.Text
  wikipediaUrl       String?  @map("wikipedia_url") @db.Text
  commonWeightMaxKg  Decimal? @map("common_weight_max_kg")
  trophyWeightMaxKg  Decimal? @map("trophy_weight_max_kg")
  uniqueWeightMaxKg  Decimal? @map("unique_weight_max_kg")
  commonCreditsPerKg Int?     @map("common_credits_per_kg")
  trophyCreditsPerKg Int?     @map("trophy_credits_per_kg")
  uniqueCreditsPerKg Int?     @map("unique_credits_per_kg")
  hookSizeMin        String?  @map("hook_size_min") @db.VarChar(10)
  hookSizeMax        String?  @map("hook_size_max") @db.VarChar(10)

  // provenance
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  baits     WikiSpeciesBait[]
  lures     WikiSpeciesLure[]
  locations WikiSpeciesLocation[]

  @@map("wiki_species")
}

// Cross-category links whose target tables (baits/lures/locations) are seeded in
// later phases. Store the wiki name + slug now; a later pass resolves the FK.
model WikiSpeciesBait {
  id        Int    @id @default(autoincrement())
  speciesId Int    @map("species_id")
  name      String @db.VarChar(120)
  slug      String @db.VarChar(160)

  species WikiSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([speciesId, name])
  @@index([speciesId])
  @@map("wiki_species_baits")
}

model WikiSpeciesLure {
  id        Int    @id @default(autoincrement())
  speciesId Int    @map("species_id")
  name      String @db.VarChar(120)
  slug      String @db.VarChar(160)

  species WikiSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([speciesId, name])
  @@index([speciesId])
  @@map("wiki_species_lures")
}

model WikiSpeciesLocation {
  id        Int    @id @default(autoincrement())
  speciesId Int    @map("species_id")
  name      String @db.VarChar(120)
  slug      String @db.VarChar(160)

  species WikiSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([speciesId, name])
  @@index([speciesId])
  @@map("wiki_species_locations")
}

model WikiBrand {
  id          Int       @id @default(autoincrement())
  slug        String    @unique @db.VarChar(160)
  name        String    @db.VarChar(120)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.Text
  sourceUrl   String?   @map("source_url") @db.Text
  contentHash String?   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime? @map("scraped_at")

  reels   WikiReel[]
  rods    WikiRod[]
  lines   WikiLine[]
  hooks   WikiHook[]
  sinkers WikiSinker[]

  @@map("wiki_brands")
}

model WikiTechnology {
  id          Int     @id @default(autoincrement())
  slug        String  @unique @db.VarChar(180)
  name        String  @db.VarChar(150)
  description String? @db.Text
  category    String? @db.VarChar(30)

  reels WikiReelTechnology[]
  rods  WikiRodTechnology[]

  @@map("wiki_technologies")
}

model WikiReel {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(160)
  name        String   @db.VarChar(150)
  subtype     String   @db.VarChar(30) // spinning | casting | saltwater
  brandId     Int?     @map("brand_id")
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  brand        WikiBrand?           @relation(fields: [brandId], references: [id])
  variants     WikiReelVariant[]
  technologies WikiReelTechnology[]

  @@index([brandId])
  @@map("wiki_reels")
}

// One row per spool size — specs and price vary per variant.
model WikiReelVariant {
  id             Int      @id @default(autoincrement())
  reelId         Int      @map("reel_id")
  spoolSize      String?  @map("spool_size") @db.Text
  gearRatio      String?  @map("gear_ratio") @db.VarChar(20)
  retrieveCm     Decimal? @map("retrieve_cm")
  maxDragKg      Decimal? @map("max_drag_kg")
  ballBearings   String?  @map("ball_bearings") @db.VarChar(20)
  weightG        Decimal? @map("weight_g")
  lineCapacity   String?  @map("line_capacity") @db.VarChar(60)
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  unlockLevel    Int?     @map("unlock_level")

  reel WikiReel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@index([reelId])
  @@map("wiki_reel_variants")
}

model WikiReelTechnology {
  reelId       Int @map("reel_id")
  technologyId Int @map("technology_id")

  reel       WikiReel       @relation(fields: [reelId], references: [id], onDelete: Cascade)
  technology WikiTechnology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([reelId, technologyId])
  @@index([technologyId])
  @@map("wiki_reel_technologies")
}

// --- Wiki tackle: gear categories (rods / lines / hooks / sinkers / bobbers / lures) ---
// Same crawl→parse→load pipeline as reels; a model that spans several variants gets
// a parent + per-variant child table. Rods reuse WikiBrand + WikiTechnology (like
// reels); lines/hooks/sinkers carry an optional brand; bobbers/lures have neither.
// Range/fraction values ("1/32 - 1/4", "3 + 3", "6'6\" NE") are stored as strings.

model WikiRod {
  id           Int      @id @default(autoincrement())
  slug         String   @unique @db.VarChar(200)
  name         String   @db.VarChar(150)
  subtype      String   @db.VarChar(40) // spinning-rods | casting-rods | …
  brandId      Int?     @map("brand_id")
  description  String?  @db.Text
  imageUrl     String?  @map("image_url") @db.Text
  power        String?  @db.VarChar(40) // shared spec hoisted to the model
  action       String?  @db.VarChar(40)
  lineWeightLb String?  @map("line_weight_lb") @db.VarChar(40) // shared line weight (else per-variant)
  lineWeightKg String?  @map("line_weight_kg") @db.VarChar(40)
  electric     Boolean? // saltwater rods
  quiverTips   String?  @map("quiver_tips") @db.Text // feeder rods
  sourceUrl    String   @map("source_url") @db.Text
  contentHash  String   @map("content_hash") @db.VarChar(64)
  scrapedAt    DateTime @map("scraped_at")

  brand        WikiBrand?          @relation(fields: [brandId], references: [id])
  variants     WikiRodVariant[]
  technologies WikiRodTechnology[]

  @@index([brandId])
  @@map("wiki_rods")
}

model WikiRodVariant {
  id             Int     @id @default(autoincrement())
  rodId          Int     @map("rod_id")
  name           String? @db.VarChar(120) // length ("6'6\" NE") or DLC edition name
  lengthFt       String? @map("length_ft") @db.VarChar(30)
  lengthM        String? @map("length_m") @db.VarChar(30)
  lureWeightOz   String? @map("lure_weight_oz") @db.VarChar(40)
  lureWeightG    String? @map("lure_weight_g") @db.VarChar(40)
  lineWeightLb   String? @map("line_weight_lb") @db.VarChar(40)
  lineWeightKg   String? @map("line_weight_kg") @db.VarChar(40)
  pieces         String? @db.VarChar(20)
  guides         String? @db.VarChar(20)
  unlockLevel    Int?    @map("unlock_level")
  priceCredits   Int?    @map("price_credits")
  priceBaitcoins Int?    @map("price_baitcoins")
  dlcPack        String? @map("dlc_pack") @db.Text

  rod WikiRod @relation(fields: [rodId], references: [id], onDelete: Cascade)

  @@index([rodId])
  @@map("wiki_rod_variants")
}

model WikiRodTechnology {
  rodId        Int @map("rod_id")
  technologyId Int @map("technology_id")

  rod        WikiRod        @relation(fields: [rodId], references: [id], onDelete: Cascade)
  technology WikiTechnology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([rodId, technologyId])
  @@index([technologyId])
  @@map("wiki_rod_technologies")
}

model WikiLine {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(200)
  name        String   @db.VarChar(150)
  subtype     String   @db.VarChar(40) // monofilament | fluorocarbon | braided | saltwater-mono | …
  kind        String   @db.VarChar(20) // regular | exclusive
  brandId     Int?     @map("brand_id")
  description String?  @db.Text
  color       String?  @db.VarChar(60)
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  brand    WikiBrand?        @relation(fields: [brandId], references: [id])
  variants WikiLineVariant[]

  @@index([brandId])
  @@map("wiki_lines")
}

// One row per (diameter × spool-size) SKU.
model WikiLineVariant {
  id             Int      @id @default(autoincrement())
  lineId         Int      @map("line_id")
  diameterMm     Decimal? @map("diameter_mm")
  diameterIn     String?  @map("diameter_in") @db.VarChar(20)
  testLb         String?  @map("test_lb") @db.VarChar(20)
  testKg         String?  @map("test_kg") @db.VarChar(20)
  color          String?  @db.VarChar(60)
  spool          String?  @db.VarChar(60) // "150 yards BASIC"
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text
  unlockLevel    Int?     @map("unlock_level")
  imageUrl       String?  @map("image_url") @db.Text
  fpId           Int?     @map("fp_id") // NNN.png icon id

  line WikiLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId])
  @@map("wiki_line_variants")
}

model WikiHook {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(200)
  name        String   @db.VarChar(150)
  kind        String   @db.VarChar(20) // hook | jighead
  subtype     String   @db.VarChar(40)
  brandId     Int?     @map("brand_id")
  type        String?  @db.VarChar(80) // plain hooks: Kirby/Octopus/…
  color       String?  @db.VarChar(60)
  sharpening  String?  @db.VarChar(40)
  count       Int? // pack count
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  brand    WikiBrand?        @relation(fields: [brandId], references: [id])
  variants WikiHookVariant[]

  @@index([brandId])
  @@map("wiki_hooks")
}

model WikiHookVariant {
  id             Int      @id @default(autoincrement())
  hookId         Int      @map("hook_id")
  size           String?  @db.VarChar(20) // "#1/0"
  weightOz       String?  @map("weight_oz") @db.VarChar(30) // jig heads
  weightG        Decimal? @map("weight_g")
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text
  unlockLevel    Int?     @map("unlock_level")
  imageUrl       String?  @map("image_url") @db.Text

  hook WikiHook @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@index([hookId])
  @@map("wiki_hook_variants")
}

model WikiSinker {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(200)
  name        String   @db.VarChar(150)
  kind        String   @db.VarChar(20) // sinker | feeder
  subtype     String   @db.VarChar(40)
  brandId     Int?     @map("brand_id")
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  brand    WikiBrand?          @relation(fields: [brandId], references: [id])
  variants WikiSinkerVariant[]

  @@index([brandId])
  @@map("wiki_sinkers")
}

model WikiSinkerVariant {
  id              Int      @id @default(autoincrement())
  sinkerId        Int      @map("sinker_id")
  weightG         Decimal? @map("weight_g")
  weightOz        String?  @map("weight_oz") @db.VarChar(30)
  capacityKg      Decimal? @map("capacity_kg") // catapults
  capacityLb      String?  @map("capacity_lb") @db.VarChar(30)
  form            String?  @db.VarChar(60) // sinkers
  count           Int?
  capacity        String?  @db.VarChar(30) // feeders: Low/Medium/High
  feederType      String?  @map("feeder_type") @db.VarChar(60)
  dissolutionTime String?  @map("dissolution_time") @db.VarChar(40)
  variantName     String?  @map("variant_name") @db.VarChar(120)
  mesh            String?  @db.VarChar(40)
  range           String?  @db.VarChar(40) // catapults
  priceCredits    Int?     @map("price_credits")
  priceBaitcoins  Int?     @map("price_baitcoins")
  priceNote       String?  @map("price_note") @db.Text
  unlockLevel     Int?     @map("unlock_level")
  imageUrl        String?  @map("image_url") @db.Text

  sinker WikiSinker @relation(fields: [sinkerId], references: [id], onDelete: Cascade)

  @@index([sinkerId])
  @@map("wiki_sinker_variants")
}

// Bobbers are one row per item (no variant child); buoys are out of scope.
model WikiBobber {
  id                Int      @id @default(autoincrement())
  slug              String   @unique @db.VarChar(200)
  name              String   @db.VarChar(150)
  subtype           String   @db.VarChar(40) // classic-bobbers | wagglers | sliders | fishing-alarm
  section           String?  @db.VarChar(20) // Regular | Exclusive
  fpId              Int?     @map("fp_id") // NNN.png image id (names collide)
  imageUrl          String?  @map("image_url") @db.Text
  description       String?  @db.Text
  color             String?  @db.VarChar(80) // float only
  size              String?  @db.VarChar(80) // float only (raw compound string)
  shape             String?  @db.VarChar(40) // float only
  maxFloatingWeight String?  @map("max_floating_weight") @db.VarChar(20) // float only
  sensitivity       String?  @db.VarChar(20) // alarm only
  material          String?  @db.VarChar(80)
  unlockLevel       Int?     @map("unlock_level")
  priceCredits      Int?     @map("price_credits")
  priceBaitcoins    Int?     @map("price_baitcoins")
  priceNote         String?  @map("price_note") @db.Text
  sourceUrl         String   @map("source_url") @db.Text
  contentHash       String   @map("content_hash") @db.VarChar(64)
  scrapedAt         DateTime @map("scraped_at")

  @@map("wiki_bobbers")
}

model WikiLure {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(200)
  name        String   @db.VarChar(150)
  subtype     String   @db.VarChar(40) // spoons | plugs | soft-plastic-baits | spinners | bass-jigs | saltwater-lures
  description String?  @db.Text
  sourceUrl   String   @map("source_url") @db.Text
  contentHash String   @map("content_hash") @db.VarChar(64)
  scrapedAt   DateTime @map("scraped_at")

  variants WikiLureVariant[]

  @@map("wiki_lures")
}

// One row per (color × size) column.
model WikiLureVariant {
  id             Int      @id @default(autoincrement())
  lureId         Int      @map("lure_id")
  color          String?  @db.VarChar(80)
  imageUrl       String?  @map("image_url") @db.Text
  buoyancy       String?  @db.VarChar(20)
  weightG        Decimal? @map("weight_g")
  lengthCm       Decimal? @map("length_cm")
  divingDepthM   Decimal? @map("diving_depth_m")
  hookSize       String?  @map("hook_size") @db.VarChar(40)
  quantity       Int?
  unlockLevel    Int?     @map("unlock_level")
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text

  lure WikiLure @relation(fields: [lureId], references: [id], onDelete: Cascade)

  @@index([lureId])
  @@map("wiki_lure_variants")
}

// Flat consumable baits (/Common_Baits, /Worms_&_Insects_Baits, /Fresh_Baits,
// /Saltwater_Baits, and the flat rows of /Event_Baits). One row per item; no
// brand/technology links (baits pages carry none). targetFish is raw species
// names (FK-resolve later, like the wiki_species_* cross-links).
model WikiBait {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @db.VarChar(200)
  name           String   @db.VarChar(150)
  subtype        String   @db.VarChar(40) // common-baits | worms-insects-baits | fresh-baits | saltwater-baits | event-baits
  fpId           Int?     @map("fp_id") // NNN.png image id (named files like Bread.png → null)
  imageUrl       String?  @map("image_url") @db.Text
  description    String?  @db.Text
  targetFish     String[] @map("target_fish")
  quantity       Int? // pack size
  weightClass    String?  @map("weight_class") @db.VarChar(20) // Light | Med-Light | Medium | Med-Heavy | Heavy | X Heavy
  unlockLevel    Int?     @map("unlock_level")
  hookSize       String?  @map("hook_size") @db.VarChar(40) // "#10 - #6", often null
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text // reward/DLC text when Price isn't a plain amount
  sourceUrl      String   @map("source_url") @db.Text
  contentHash    String   @map("content_hash") @db.VarChar(64)
  scrapedAt      DateTime @map("scraped_at")

  @@map("wiki_baits")
}

// Boilies and pellets (/Boilies_&_Pellets_Baits + the boilie sub-section of
// /Event_Baits). One row per item, flattened from the block-per-model columns
// (each variant column is its own purchasable item; the block has no title).
model WikiBoilie {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @db.VarChar(200)
  name           String   @db.VarChar(150)
  subtype        String   @db.VarChar(40) // boilies-pellets-baits | event-baits
  fpId           Int?     @map("fp_id")
  imageUrl       String?  @map("image_url") @db.Text // main Boilies/Pellets image
  boilImageUrl   String?  @map("boil_image_url") @db.Text // Boil hookbait image (boilies only)
  description    String?  @db.Text // event boilies only
  sizeIn         String?  @map("size_in") @db.VarChar(20)
  sizeMm         String?  @map("size_mm") @db.VarChar(20)
  targetFish     String[] @map("target_fish")
  flavour        String?  @db.VarChar(80)
  color          String?  @db.VarChar(80)
  buoyancy       String?  @db.VarChar(20) // Sinking | Pop-Up
  weightClass    String?  @map("weight_class") @db.VarChar(20)
  quantity       Int?
  unlockLevel    Int?     @map("unlock_level")
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text
  sourceUrl      String   @map("source_url") @db.Text
  contentHash    String   @map("content_hash") @db.VarChar(64)
  scrapedAt      DateTime @map("scraped_at")

  @@map("wiki_boilies")
}

// Groundbaits — feed/attractant consumables. One table over both page layouts:
// flat catalogs (aromas, particles) and the flattened block-per-model mixes
// (carp/base/method-mix). Subtype-specific columns are null off-subtype (same
// shape as wiki_bobbers). No brand FK — the flat pages' brand is kept as a raw
// name (FK-resolve later); mix pages carry none.
model WikiGroundbait {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @db.VarChar(200)
  name           String   @db.VarChar(150)
  subtype        String   @db.VarChar(40) // aromas | particles | carp-groundbaits | groundbait-base | method-mix-groundbaits
  fpId           Int?     @map("fp_id")
  imageUrl       String?  @map("image_url") @db.Text
  brand          String?  @db.VarChar(80) // flat pages only (raw name)
  description    String?  @db.Text // flat pages only
  targetFish     String[] @map("target_fish")
  temperature    String?  @db.VarChar(80) // flat "Weather Conditions" (can be a phrase) / mix "Temperature"
  aroma          String?  @db.VarChar(120) // aromas + base
  effect         String?  @db.VarChar(60) // aromas only
  contains       String?  @db.VarChar(120) // particles only
  flavour        String?  @db.VarChar(80) // carp/method only
  color          String?  @db.VarChar(80) // carp/method only
  grain          String?  @db.VarChar(40) // base only
  density        String?  @db.VarChar(40) // base only
  ponds          String?  @db.VarChar(120) // mix pages
  nutritionValue String?  @map("nutrition_value") @db.VarChar(40) // mix pages
  sizeMm         String?  @map("size_mm") @db.VarChar(20) // carp only
  weight         String?  @db.VarChar(30) // raw ("2.2 / 1.0" lb/kg flat, or kg on mixes)
  priceCredits   Int?     @map("price_credits")
  priceBaitcoins Int?     @map("price_baitcoins")
  priceNote      String?  @map("price_note") @db.Text
  unlockLevel    Int?     @map("unlock_level")
  sourceUrl      String   @map("source_url") @db.Text
  contentHash    String   @map("content_hash") @db.VarChar(64)
  scrapedAt      DateTime @map("scraped_at")

  @@map("wiki_groundbaits")
}

// Equipment — apparel (glasses/hats/waistcoats), storage (rod-cases/tackle-boxes),
// rod-holders, and stringers/keepnets. One table over all 7 pages; columns vary a
// lot per subtype and are null off-subtype (wiki_bobbers pattern). Flat pages are
// one-row-per-item; the stringers-keepnets page's merged model×size grid is
// captured one-row-per-product-line, with the size weights folded to a range.
model WikiEquipment {
  id                    Int      @id @default(autoincrement())
  slug                  String   @unique @db.VarChar(200)
  name                  String   @db.VarChar(150)
  subtype               String   @db.VarChar(40) // glasses-and-flashlights | hats | rod-cases | tackle-boxes | waist-coats | rod-holders | stringers-keepnets
  fpId                  Int?     @map("fp_id")
  imageUrl              String?  @map("image_url") @db.Text
  brand                 String?  @db.VarChar(80) // explicit Brand column / block header (raw name)
  description           String?  @db.Text
  material              String?  @db.VarChar(150)
  color                 String?  @db.VarChar(60) // glasses
  tackles               String?  @db.VarChar(20) // hats — tackle-slot capacity
  flashlight            String?  @db.VarChar(20) // hats
  flashlightSlot        String?  @map("flashlight_slot") @db.VarChar(20) // hats
  storageCapacity       String?  @map("storage_capacity") @db.VarChar(150) // cases/boxes/waistcoats
  rodSlot               String?  @map("rod_slot") @db.VarChar(20) // rod-holders
  standCount            String?  @map("stand_count") @db.VarChar(20) // rod-holders
  biteAlarm             String?  @map("bite_alarm") @db.VarChar(20) // rod-holders
  weight                String?  @db.VarChar(30) // rod-holders (raw "lb / kg")
  maxSingleFishWeightKg String?  @map("max_single_fish_weight_kg") @db.VarChar(30) // stringers-keepnets (range)
  maxTotalFishWeightKg  String?  @map("max_total_fish_weight_kg") @db.VarChar(30) // stringers-keepnets (range)
  fishFriendly          String?  @map("fish_friendly") @db.VarChar(20) // stringers-keepnets
  durability            String?  @db.VarChar(40) // stringers-keepnets
  priceCredits          Int?     @map("price_credits")
  priceBaitcoins        Int?     @map("price_baitcoins")
  priceNote             String?  @map("price_note") @db.Text // reward/DLC unlock text (most cosmetics)
  unlockLevel           Int?     @map("unlock_level")
  sourceUrl             String   @map("source_url") @db.Text
  contentHash           String   @map("content_hash") @db.VarChar(64)
  scrapedAt             DateTime @map("scraped_at")

  @@map("wiki_equipment")
}
